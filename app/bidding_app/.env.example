# Environment Configuration Example
# Copy this file to .env and update with your values

# Development - Android Emulator (Default)
ANDROID_EMULATOR_URL=http://10.0.2.2:5000

# Development - iOS Simulator
IOS_SIMULATOR_URL=http://localhost:5000

# Development - Physical Device (Replace with your PC's IP address)
# To find your IP:
#   Windows: ipconfig (look for IPv4 Address)
#   Mac/Linux: ifconfig (look for inet address)
LOCAL_NETWORK_URL=http://192.168.1.100:5000

# Production
PRODUCTION_URL=https://api.bidmaster.com

# Notes:
# - 10.0.2.2 is Android Emulator's special alias to access host machine's localhost
# - For physical devices, you MUST use your computer's actual IP address on the network
# - Make sure your firewall allows connections on port 5000
